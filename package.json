{
  "name": "ui-elements",
  "version": "10.0.0",
  "description": "A repo of ui elements",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/localnerve/ui-elements.git"
  },
  "scripts": {
    "rmdist": "node -e 'require(\"fs\").rmSync(\"dist\", {recursive:true,force:true})'",
    "prebuild": "npm run rmdist",
    "build": "npm run installs && gulp webpack && gulp copy",
    "prebuild:dev": "npm run rmdist",
    "build:dev": "gulp webpack-dev && gulp copy",
    "lint": "eslint .",
    "installs": "gulp installs",
    "copy": "gulp copy",
    "dev": "npm run build:dev && node index.js",
    "test": "npm run build && npm run lint && playwright test",
    "test:debug": "npm run build && npm run lint && playwright test --headed --timeout=60000",
    "start": "npm run build && node index.js"
  },
  "keywords": [
    "localnerve",
    "ui",
    "elements"
  ],
  "author": "Alex Grant <alex@localnerve.com> (https://www.localnerve.com)",
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "babel-loader": "^10.1.1",
    "eslint": "^10.4.0",
    "eslint-plugin-n": "18.0.1",
    "express": "^5.2.1",
    "globals": "^17.6.0",
    "gulp": "^5.0.1",
    "picklr": "latest",
    "terser-webpack-plugin": "^5.6.0",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  },
  "engines": {
    "node": ">=22"
  }
}
